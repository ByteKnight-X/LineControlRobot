<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
  <class>ImportTaskPage</class>

  <widget class="QWidget" name="ImportTaskPage">
    <property name="styleSheet">
      <string>
        /* ===== Ant Design 页面样式 ===== */
        QWidget#ImportTaskPage {
          background-color: #f0f2f5;
        }

        /* 主要按钮 */
        QPushButton {
          background-color: #ffffff;
          border: 1px solid #d9d9d9;
          border-radius: 6px;
          padding: 6px 12px;
          font-size: 13px;
          color: #333333;
          min-height: 28px;
          max-height: 36px;
        }
        QPushButton:hover {
          color: #1890ff;
          border-color: #1890ff;
        }
        QPushButton:pressed {
          color: #096dd9;
          border-color: #096dd9;
        }

        /* 绿色关键操作按钮 */
        QPushButton#btnSyncErp, QPushButton#btnImportOrder, QPushButton#btnImportBatch,
        QPushButton#btnAIOptimize, QPushButton#btnValidate {
          background-color: #52c41a;
          border-color: #52c41a;
          color: #ffffff;
          font-weight: 600;
        }
        QPushButton#btnSyncErp:hover, QPushButton#btnImportOrder:hover, QPushButton#btnImportBatch:hover,
        QPushButton#btnAIOptimize:hover, QPushButton#btnValidate:hover {
          background-color: #73d13d;
          border-color: #73d13d;
        }
        QPushButton#btnSyncErp:pressed, QPushButton#btnImportOrder:pressed, QPushButton#btnImportBatch:pressed,
        QPushButton#btnAIOptimize:pressed, QPushButton#btnValidate:pressed {
          background-color: #389e0d;
          border-color: #389e0d;
        }

        /* 卡片样式 */
        QFrame#topBar, QFrame#searchBar, QFrame#orderCard, QFrame#batchCard, QFrame#infoCard {
          background-color: #ffffff;
          border: 1px solid #f0f0f0;
          border-radius: 8px;
        }

        /* 输入框 */
        QLineEdit, QSpinBox, QDoubleSpinBox, QDateEdit, QComboBox {
          background-color: #ffffff;
          border: 1px solid #d9d9d9;
          border-radius: 4px;
          padding: 4px 8px;
          font-size: 13px;
          min-height: 26px;
          max-height: 32px;
        }
        QLineEdit:focus, QSpinBox:focus, QDoubleSpinBox:focus, QDateEdit:focus, QComboBox:focus {
          border-color: #1890ff;
        }
        QLineEdit:hover, QSpinBox:hover, QDoubleSpinBox:hover, QDateEdit:hover, QComboBox:hover {
          border-color: #40a9ff;
        }

        /* 表格样式 */
        QTableView, QTableWidget {
          background-color: #ffffff;
          border: 1px solid #f0f0f0;
          border-radius: 4px;
          gridline-color: #f0f0f0;
          font-size: 13px;
        }
        QTableView::item, QTableWidget::item {
          padding: 8px;
          border-bottom: 1px solid #f0f0f0;
        }
        QTableView::item:selected, QTableWidget::item:selected {
          background-color: #e6f7ff;
          color: #1890ff;
        }
        QHeaderView::section {
          background-color: #fafafa;
          border: none;
          border-bottom: 1px solid #f0f0f0;
          padding: 8px;
          font-weight: 600;
          font-size: 13px;
          color: #262626;
        }

        QLabel { font-size: 13px; color: #262626; }
        QLabel#stepsLabel { font-size: 12px; color: #8c8c8c; }
        QLabel#lblOrderTitle, QLabel#lblBatchTitle, QLabel#lblInfoTitle {
          font-size: 14px; font-weight: 600; color: #262626;
        }

        QSplitter::handle { background-color: #f0f0f0; width: 12px; }
        QSplitter::handle:hover { background-color: #1890ff; }
      </string>
    </property>

    <layout class="QVBoxLayout" name="mainLayout">
      <property name="spacing"><number>12</number></property>
      <property name="leftMargin"><number>0</number></property>
      <property name="topMargin"><number>0</number></property>
      <property name="rightMargin"><number>0</number></property>
      <property name="bottomMargin"><number>0</number></property>

      <!-- 1) 顶部控制栏 -->
      <item>
        <widget class="QFrame" name="topBar">
          <property name="frameShape"><enum>QFrame::NoFrame</enum></property>
          <property name="maximumSize"><size><width>16777215</width><height>60</height></size></property>
          <layout class="QHBoxLayout" name="topBarLayout">
            <property name="leftMargin"><number>16</number></property>
            <property name="topMargin"><number>10</number></property>
            <property name="rightMargin"><number>16</number></property>
            <property name="bottomMargin"><number>10</number></property>
