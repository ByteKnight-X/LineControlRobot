<ui version="4.0">
 <class>ProductionPreparationWidget</class>
 <widget class="QWidget" name="ProductionPreparationWidget">
  <layout class="QVBoxLayout" name="prepLayout">
    <!-- Top area: contains all elements except the start button, vertically centered -->
    <item stretch="1">
      <widget class="QTextEdit" name="preparationTextEdit">
        <property name="sizePolicy">
          <sizepolicy hsizetype="Expanding" vsizetype="Expanding">
            <horstretch>1</horstretch>
            <verstretch>1</verstretch>
          </sizepolicy>
