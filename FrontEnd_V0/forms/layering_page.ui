<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>LayeringPage</class>
 <widget class="QWidget" name="LayeringPage">
  <layout class="QVBoxLayout" name="verticalLayout_layering">
   <item stretch="1">
    <layout class="QHBoxLayout" name="mainHorizontalLayout">
     <!-- Directory -->
     <item stretch="1">
      <widget class="QWidget" name="directoryPanel">
       <property name="sizePolicy">
        <sizepolicy hsizetype="Preferred" vsizetype="Expanding">
         <horstretch>0</horstretch><verstretch>0</verstretch>
        </sizepolicy>
       </property>
       <property name="minimumWidth">
        <number>140</number>
       </property>
       <property name="maximumWidth">
        <number>240</number>
       </property>
       <layout class="QVBoxLayout" name="directoryLayout">
        <item stretch="1">
         <widget class="QScrollArea" name="thumbnailsScroll">
          <property name="widgetResizable"><bool>true</bool></property>
          <widget class="QWidget" name="thumbnailsContainer">
           <layout class="QVBoxLayout" name="thumbnailsLayout">
            <item>
             <widget class="QListWidget" name="thumbnailsList">
              <property name="sizePolicy">
               <sizepolicy hsizetype="Expanding" vsizetype="Expanding">
                <horstretch>0</horstretch><verstretch>0</verstretch>
               </sizepolicy>
              </property>
              <property name="selectionMode">
               <enum>QAbstractItemView::SingleSelection</enum>
              </property>
             </widget>
            </item>
            <item>
             <spacer name="thumbsBottomSpacer">
              <property name="orientation"><enum>Qt::Vertical</enum></property>
              <property name="sizeType"><enum>QSizePolicy::Expanding</enum></property>
             </spacer>
            </item>
           </layout>
          </widget>
         </widget>
        </item>
       </layout>
      </widget>
     </item>
     <!-- Preview panel (center) -->
     <item stretch="3">
      <widget class="QWidget" name="previewPanel">
       <property name="sizePolicy">
        <sizepolicy hsizetype="Expanding" vsizetype="Expanding">
         <horstretch>0</horstretch><verstretch>0</verstretch>
        </sizepolicy>
       </property>
       <property name="minimumWidth">
        <number>400</number>
       </property>
       <layout class="QVBoxLayout" name="previewVerticalLayout">
        <item stretch="10">
         <widget class="QWidget" name="layerPreviewPanel">
          <layout class="QVBoxLayout" name="layerPreviewInnerLayout">
           <item>
            <!-- layerPreview rewritten as QWebEngineView to render SVG reliably -->
            <widget class="QWebEngineView" name="layerPreview">
             <property name="sizePolicy">
              <sizepolicy hsizetype="Expanding" vsizetype="Expanding">
               <horstretch>0</horstretch><verstretch>0</verstretch>
              </sizepolicy>
             </property>
             <property name="styleSheet">
              <string>border:1px solid #888888; background-color:white;</string>
             </property>
            </widget>
           </item>
          </layout>
         </widget>
        </item>
        <item stretch="1">
         <widget class="QWidget" name="previewNavPanel">
          <layout class="QHBoxLayout" name="previewNavLayout">
           <item>
            <widget class="QPushButton" name="btnPrevLayer">
             <property name="text"><string>&lt;</string></property>
            </widget>
           </item>
           <item>
            <spacer name="navLeftSpacer">
             <property name="orientation"><enum>Qt::Horizontal</enum></property>
             <property name="sizeType"><enum>QSizePolicy::Expanding</enum></property>
            </spacer>
           </item>
           <item>
            <widget class="QLabel" name="layerIndexLabel">
             <property name="text"><string>0 / 0</string></property>
             <property name="alignment"><set>Qt::AlignCenter</set></property>
             <property name="minimumSize">
              <size><width>90</width><height>24</height></size>
             </property>
            </widget>
           </item>
           <item>
            <spacer name="navRightSpacer">
             <property name="orientation"><enum>Qt::Horizontal</enum></property>
             <property name="sizeType"><enum>QSizePolicy::Expanding</enum></property>
            </spacer>
           </item>
           <item>
            <widget class="QPushButton" name="btnNextLayer">
             <property name="text"><string>&gt;</string></property>
            </widget>
           </item>
          </layout>
         </widget>
        </item>
       </layout>
      </widget>
     </item>
     <!-- Parameters panel -->
     <item stretch="2">
      <widget class="QWidget" name="rightPanel">
       <property name="sizePolicy">
        <sizepolicy hsizetype="Preferred" vsizetype="Expanding">
         <horstretch>0</horstretch><verstretch>0</verstretch>
        </sizepolicy>
       </property>
       <property name="minimumWidth">
        <number>160</number>
       </property>
       <property name="maximumWidth">
        <number>400</number>
       </property>
       <layout class="QVBoxLayout" name="rightPanelLayout">
        <item>
         <widget class="QWidget" name="parametersPanel">
          <layout class="QFormLayout" name="paramsForm">
           <!-- Mesh parameters -->
           <item row="0" column="0">
            <widget class="QLabel" name="labelMaterial">
             <property name="text"><string>材质</string></property>
            </widget>
           </item>
           <item row="0" column="1">
            <widget class="QLineEdit" name="materialLineEdit"/>
           </item>
           <item row="1" column="0">
            <widget class="QLabel" name="labelModel">
             <property name="text"><string>型号</string></property>
            </widget>
           </item>
           <item row="1" column="1">
            <widget class="QLineEdit" name="modelLineEdit"/>
           </item>
           <item row="2" column="0">
            <widget class="QLabel" name="labelWireDiameter">
             <property name="text"><string>线径</string></property>
            </widget>
           </item>
           <item row="2" column="1">
            <widget class="QLineEdit" name="wireDiameterLineEdit"/>
           </item>
           <!-- Weaving method parameters -->
           <item row="3" column="0">
            <widget class="QLabel" name="labelPullingMethod">
             <property name="text"><string>拉线方法</string></property>
            </widget>
           </item>
           <item row="3" column="1">
            <widget class="QComboBox" name="pullingMethodCombo">
             <item><property name="text"><string>直拉</string></property></item>
             <item><property name="text"><string>斜拉</string></property></item>
            </widget>
           </item>
           <item row="4" column="0">
            <widget class="QLabel" name="labelPullingAngle">
             <property name="text"><string>拉线角度</string></property>
            </widget>
           </item>
           <item row="4" column="1">
            <widget class="QLineEdit" name="pullingAngleLineEdit"/>
           </item>
           <item row="5" column="0">
            <widget class="QLabel" name="labelMeshCount">
             <property name="text"><string>目数</string></property>
            </widget>
           </item>
           <item row="5" column="1">
            <widget class="QLineEdit" name="meshCountLineEdit"/>
           </item>
           <item row="6" column="0">
            <widget class="QLabel" name="labelTension">
             <property name="text"><string>张力</string></property>
            </widget>
           </item>
           <item row="6" column="1">
            <widget class="QLineEdit" name="tensionLineEdit"/>
           </item>
           <!-- Frame parameters -->
           <item row="7" column="0">
            <widget class="QLabel" name="labelFrameModel">
             <property name="text"><string>网框规格</string></property>
            </widget>
           </item>
           <item row="7" column="1">
            <widget class="QLineEdit" name="frameModelLineEdit"/>
           </item>
           <item row="8" column="0">
           <widget class="QPushButton" name="btnEditParams">
            <property name="text"><string>编辑参数</string></property>
           </widget>
          </item>
           <item row="8" column="1">
           <widget class="QPushButton" name="btnSaveParams">
            <property name="text"><string>保存参数</string></property>
           </widget>
          </item>
          </layout>
         </widget>
        </item>
        <item>
         <layout class="QVBoxLayout" name="paramsButtonsLayout">
          <item>
           <widget class="QPushButton" name="btnNextStep">
            <property name="text"><string>下一步</string></property>
           </widget>
          </item>
         </layout>
        </item>
        <item>
         <spacer name="rightBottomSpacer">
          <property name="orientation"><enum>Qt::Vertical</enum></property>
          <property name="sizeType"><enum>QSizePolicy::Expanding</enum></property>
         </spacer>
        </item>
       </layout>
      </widget>
     </item>
    </layout>
   </item>
  </layout>
 </widget>

 <customwidgets>
  <customwidget class="QWebEngineView" name="QWebEngineView">
   <header>PyQt5.QtWebEngineWidgets</header>
   <container>1</container>
  </customwidget>
 </customwidgets>

 <resources/>
 <connections/>
</ui>
